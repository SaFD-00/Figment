# Figment — copy to backend/.env (frontend reads NEXT_PUBLIC_* from frontend/.env.local)
# ───────────────────────────────────────────────────────────────────────────
# Figment unifies a CLOUD engine (OpenRouter API) and a LOCAL engine
# (ComfyUI + Ollama). You can run with only one of them configured:
#   • Cloud only  → set OPENROUTER_API_KEY; ComfyUI/Ollama optional.
#   • Local only  → run ComfyUI + Ollama; no API keys needed.
#   • Both        → users pick any model in the in-app picker (inline pill in the composer).
#
# Models are chosen IN THE UI, not here. The model ids below are only FALLBACK DEFAULTS,
# used when nothing is selected (and for FigGen sub-roles not exposed in the picker). This
# file is really just API keys + service URLs + fallbacks.
# ───────────────────────────────────────────────────────────────────────────

# ── Cloud engine (FigGen-derived): LLM + image via OpenRouter ───────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
FIGGEN_PROVIDER=openrouter       # openrouter | auto | mock  (no key → safe mock fallback)
FIGGEN_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Fallback cloud model ids for the figure pipeline. When the user picks a cloud LLM in the UI,
# its slug overrides planner/classifier/vision/chart_coder/research per job (see
# engines/figure_pipeline.py:_job_settings). These are only used when nothing is selected.
# The LLM lineup is vision-capable only, so every reasoning role defaults to a multimodal slug.
FIGGEN_PLANNER_MODEL=google/gemini-2.5-flash
FIGGEN_CLASSIFIER_MODEL=google/gemini-2.5-flash
FIGGEN_VISION_MODEL=google/gemini-2.5-flash      # multimodal (VL) for critic/reference analysis
FIGGEN_CHART_CODER_MODEL=google/gemini-2.5-flash
# API 이미지 default. env 미설정 시 figure_engine 소스 기본값(openai/gpt-5.4-image-2)으로 폴백.
FIGGEN_DEFAULT_IMAGER=google/gemini-3.1-flash-image
FIGGEN_RESEARCH_ENABLED=false
FIGGEN_RESEARCH_MODEL=google/gemini-2.5-flash
FIGGEN_CRITIC_ENABLED=true
FIGGEN_MAX_CRITIC_ITERS=2

# ── Local engine (ImgGen-derived): ComfyUI + Ollama ────────────────────────
# Runtime home for local weights, ComfyUI, SQLite DB, logs, outputs.
# Defaults to <repo>/AIStudio. Per AGENTS.md, <repo>/AIStudio is normally a SYMLINK to
# /data/<user>/Figment/AIStudio (the big /data volume) — scripts/00_bootstrap_dirs.sh creates it.
# Alternatively, point this directly at a /data path instead of symlinking:
# AISTUDIO_HOME="/data/<user>/Figment/AIStudio"
# HuggingFace token (read-scope) for fast model downloads (scripts/20_download_models.sh).
HF_TOKEN=your_hf_token_here
COMFY_URL=http://127.0.0.1:8188
OLLAMA_URL=http://127.0.0.1:11434
# Where Ollama stores pulled LLM weights. The root volume is small, so keep this on /data.
# Defaults (in scripts/31_run_ollama.sh) to $AISTUDIO_HOME/ollama — which is already the /data
# symlink — so you normally don't need to set this. Override only to point elsewhere.
# OLLAMA_MODELS="/data/<user>/Figment/AIStudio/ollama"
# Default chat/planner LLM. The UI picker overrides this per chat turn (local LLM → its Ollama
# tag, cloud LLM → OpenRouter). Used only when no LLM is selected. The lineup is vision-capable
# only, so the local default is the multimodal qwen3-vl (image-grounded prompt-enhance).
OLLAMA_LLM=huihui_ai/qwen3-vl-abliterated:8b
# Memory budget (GB) — VRAM on a single NVIDIA H100 80GB (the local engine target). Leaves
# headroom under 80GB for the co-resident photoreal stack. Must match config.py's default.
VRAM_BUDGET_GB=78
LLM_RESIDENT_GB=5.0

# ── Server ─────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
