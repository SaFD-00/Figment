# Figment — copy to backend/.env (frontend reads NEXT_PUBLIC_* from frontend/.env.local)
# ───────────────────────────────────────────────────────────────────────────
# Figment unifies a CLOUD engine (OpenRouter API) and a LOCAL engine
# (ComfyUI + Ollama). You can run with only one of them configured:
#   • Cloud only  → set OPENROUTER_API_KEY; ComfyUI/Ollama optional.
#   • Local only  → run ComfyUI + Ollama; no API keys needed.
#   • Both        → users pick any model in the in-app picker (inline pill in the composer).
#
# Models are chosen IN THE UI, not here. The model ids below are only FALLBACK DEFAULTS,
# used when nothing is selected (and for FigGen sub-roles not exposed in the picker). This
# file is really just API keys + service URLs + fallbacks.
# ───────────────────────────────────────────────────────────────────────────

# ── Cloud engine (FigGen-derived): LLM + image via OpenRouter ───────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
FIGGEN_PROVIDER=openrouter       # openrouter | auto | mock  (no key → safe mock fallback)
FIGGEN_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Fallback cloud model ids for the figure pipeline. When the user picks a cloud LLM in the UI,
# its slug overrides planner/classifier/vision/chart_coder/research per job (see
# engines/figure_pipeline.py:_job_settings). These are only used when nothing is selected.
FIGGEN_PLANNER_MODEL=qwen/qwen3.7-plus
FIGGEN_CLASSIFIER_MODEL=qwen/qwen3.6-flash
FIGGEN_VISION_MODEL=qwen/qwen3.7-plus            # VERIFY: must be VL (multimodal) for critic/reference analysis
FIGGEN_CHART_CODER_MODEL=qwen/qwen3.7-plus
FIGGEN_DEFAULT_IMAGER=bytedance-seed/seedream-4.5
FIGGEN_RESEARCH_ENABLED=false
FIGGEN_RESEARCH_MODEL=qwen/qwen3.7-plus
FIGGEN_CRITIC_ENABLED=true
FIGGEN_MAX_CRITIC_ITERS=2

# ── Local engine (ImgGen-derived): ComfyUI + Ollama ────────────────────────
# Runtime home for local weights, ComfyUI, SQLite DB, logs, outputs.
# Defaults to <repo>/AIStudio so the project is self-contained.
# AISTUDIO_HOME="/some/other/path/AIStudio"
# HuggingFace token (read-scope) for fast model downloads (scripts/20_download_models.sh).
HF_TOKEN=your_hf_token_here
COMFY_URL=http://127.0.0.1:8188
OLLAMA_URL=http://127.0.0.1:11434
# Default chat/planner LLM. The UI picker overrides this per chat turn (local LLM → its Ollama
# tag, cloud LLM → OpenRouter). Used only when no LLM is selected. _FALLBACK is the lighter
# model the memory orchestrator downshifts to under pressure.
OLLAMA_LLM=hf.co/HauhauCS/Qwen3.5-9B-Uncensored-HauhauCS-Aggressive:Q4_K_M
OLLAMA_LLM_FALLBACK=hf.co/HauhauCS/Qwen3.5-4B-Uncensored-HauhauCS-Aggressive:Q4_K_M
# Memory budget (GB) — usable unified memory for ML on a 24GB M4 Pro
VRAM_BUDGET_GB=19
LLM_RESIDENT_GB=5

# ── Server ─────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
