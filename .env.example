# Figment — copy to the repo-root .env (the backend and cloud engine both read this file)
# ───────────────────────────────────────────────────────────────────────────
# Figment unifies a CLOUD engine (OpenRouter API) and a LOCAL engine
# (ComfyUI + Ollama). Run with either or both configured:
#   • Cloud only  → set OPENROUTER_API_KEY; ComfyUI/Ollama optional.
#   • Local only  → run ComfyUI + Ollama; no API keys needed.
#   • Both        → pick any model in the in-app picker.
#
# Models are chosen IN THE UI. Cloud model fallbacks (planner/vision/imager/…) and the other
# FIGGEN_* knobs are intentionally left out — they fall back to code defaults. Add a FIGGEN_*
# line to .env only when you need to override one.
# ───────────────────────────────────────────────────────────────────────────

# ── Cloud engine (OpenRouter): chat LLM + figure pipeline ──────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
FIGGEN_PROVIDER=openrouter       # openrouter | auto | mock  (no key → safe mock fallback)

# ── Local engine (ComfyUI + Ollama) ───────────────────────────────────────
# HuggingFace token (read-scope) for model downloads — scripts/20_download_models.sh.
HF_TOKEN=your_hf_token_here
COMFY_URL=http://127.0.0.1:8188
OLLAMA_URL=http://127.0.0.1:11434
# Default chat/planner LLM — the single local Ollama model (the UI picker overrides per turn).
# Uncensored multimodal (vision) so local prompt-enhance can read an uploaded edit/reference image.
OLLAMA_LLM=huihui_ai/qwen3-vl-abliterated:8b
# Runtime home for weights / ComfyUI / SQLite DB / logs / outputs. Defaults to <repo>/AIStudio.
# AISTUDIO_HOME="/some/other/path/AIStudio"
# Memory budget (GB) — usable unified memory for ML on a 24GB M4 Pro.
VRAM_BUDGET_GB=19
LLM_RESIDENT_GB=5

# ── Server ─────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
